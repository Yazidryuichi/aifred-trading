# =============================================================================
# AIFred Trading Engine — Docker Environment Variables
# Copy this file to .env and fill in your actual API keys.
#
#   cp .env.docker .env
#   # Edit .env with your real credentials
#   docker compose up -d
#
# IMPORTANT: Never commit .env with real keys. Only .env.docker is safe to commit.
# =============================================================================

# Trading mode: paper (simulated) or live (real orders)
TRADING_MODE=paper

# --- Exchange API Keys ---

# Binance (crypto trading)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Alpaca (US stocks)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_api_secret_here

# --- AI / NLP ---

# Anthropic Claude (LLM sentiment analysis)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Monitoring ---

# Telegram alerts (optional — leave blank to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Database ---

# SQLite is the default; no config needed (files stored in ./data/)
# Uncomment below to use PostgreSQL instead:
# DATABASE_URL=postgresql://user:password@host:5432/aifred

# Redis (optional — for caching)
# REDIS_URL=redis://localhost:6379
