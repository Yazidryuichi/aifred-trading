# AI Trading Bot — Environment Variables
# Copy to .env and fill in your values

# Exchange API Keys
BINANCE_API_KEY=
BINANCE_SECRET=
ALPACA_API_KEY=
ALPACA_SECRET=
OANDA_API_KEY=
OANDA_ACCOUNT_ID=

# NLP / LLM
ANTHROPIC_API_KEY=
NEWSAPI_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=trading-bot/1.0

# Monitoring
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Database (optional — defaults to SQLite)
DATABASE_URL=sqlite:///data/trading.db
REDIS_URL=redis://localhost:6379

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# Hyperliquid wallet address
# Server-side (API routes):
HYPERLIQUID_WALLET_ADDRESS=0xbec07623d9c8209E7F80dC7350b3aA0ECBdCb510
# Client-side (hooks, components — needs NEXT_PUBLIC_ prefix):
NEXT_PUBLIC_HYPERLIQUID_ADDRESS=0xbec07623d9c8209E7F80dC7350b3aA0ECBdCb510

# Trading Mode (paper | live) — NEXT_PUBLIC_ prefix exposes to client-side
NEXT_PUBLIC_TRADING_MODE=paper
